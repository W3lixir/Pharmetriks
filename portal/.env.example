# ─── Supabase ────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi…   # anon / public key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi…       # SERVICE ROLE — keep secret, server-only

# Mirror for server-side scripts (seed-admin, etc.). Same value as the public URL.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# ─── Admin seed ──────────────────────────────────────────────────────────
ADMIN_EMAIL=your-admin-email@example.com
# Leave ADMIN_PASSWORD blank to auto-generate a one-time random password
# (printed once in the terminal when you run `npm run seed:admin`).
ADMIN_PASSWORD=

# ─── App ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Pharmetriks
NEXT_PUBLIC_APP_PRICE_PHP=249
# Flat one-time price per add-on feature (selected at checkout).
NEXT_PUBLIC_ADDON_PRICE_PHP=99

# Public origin of the deployed site (no trailing slash). Used in the /logout
# redirect. In dev, http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GCash receiver shown on /upload-receipt.
NEXT_PUBLIC_GCASH_NUMBER=+63 991 381 ••••
NEXT_PUBLIC_GCASH_NAME=KA*L TR****N O.

# Optional — support contact channels. Each one rendered as a fallback.
# The HelpButton hides itself entirely if all three are blank.
NEXT_PUBLIC_SUPPORT_MESSENGER_URL=
NEXT_PUBLIC_SUPPORT_WHATSAPP_URL=
NEXT_PUBLIC_SUPPORT_EMAIL=
