# ─── Secrets / env ──────────────────────────────────────────────────
# Never commit any .env file containing real values. .env.example is the
# only allow-listed env file (no secrets, only placeholders).
.env
.env.*
!.env.example

# Just in case anyone names them with the .env at the back
*.env
*.env.local

# ─── Node / Next.js ─────────────────────────────────────────────────
node_modules/
.next/
out/
dist/
build/
.vercel/
.turbo/
*.tsbuildinfo
next-env.d.ts

# ─── Editor / OS ────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ─── Logs / temp ────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Backups ────────────────────────────────────────────────────────
*.bak
*.backup
*.orig
*.tmp

# ─── Test artifacts / coverage ──────────────────────────────────────
coverage/
.nyc_output/

# ─── User-uploaded receipts (just in case anyone dumps them locally) ─
receipts/
uploads/
*.heic
*.heif

# ─── Personal artifacts ─────────────────────────────────────────────
# Anything dropped into _assets/ is treated as scratch — sample QRs,
# screenshots, etc. should never be committed.
_assets/
**/_assets/
scratch/
notes-personal.md
TODO-personal.md
.vercel
